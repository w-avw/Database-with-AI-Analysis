          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT \n  DATE_TRUNC('hour', date_time) as time,\n  COUNT(*) FILTER (WHERE disconnection_cause = '034 - Error in SBS') as \"SBS Errors\",\n  COUNT(*) FILTER (WHERE disconnection_cause = '016 - Unknown TETRA identity') as \"TETRA Identity Errors\",\n  COUNT(*) FILTER (WHERE disconnection_cause = '019 - Call restoration of the other user failed') as \"Restoration Failures\",\n  COUNT(*) FILTER (WHERE disconnection_cause = '014 - SwMI requested disconnection') as \"SwMI Disconnections\"\nFROM call_records \nWHERE date_time IS NOT NULL \nGROUP BY DATE_TRUNC('hour', date_time) \nORDER BY time;",
          "refId": "A"
        }
      ],
      "title": "🚨 System Failures Over Time",
      "type": "timeseries"
