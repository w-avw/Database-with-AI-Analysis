{
  "dashboard": {
    "id": null,
    "title": "Universal DB - Call Analytics Dashboard",
    "tags": ["universal-db", "call-analytics"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Total Call Records",
        "type": "stat",
        "targets": [
          {
            "expr": "",
            "format": "time_series",
            "intervalFactor": 1,
            "rawSql": "SELECT COUNT(*) as value FROM call_records",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "align": "auto",
              "displayMode": "auto"
            },
            "mappings": [],
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Calls by Source Type",
        "type": "piechart",
        "targets": [
          {
            "expr": "",
            "format": "time_series",
            "intervalFactor": 1,
            "rawSql": "SELECT source_type as metric, COUNT(*) as value FROM call_records GROUP BY source_type ORDER BY COUNT(*) DESC",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "hideFrom": {
                "tooltip": false,
                "vis": false,
                "legend": false
              }
            },
            "mappings": []
          }
        },
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 6,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Average Call Duration (seconds)",
        "type": "stat",
        "targets": [
          {
            "expr": "",
            "format": "time_series",
            "intervalFactor": 1,
            "rawSql": "SELECT AVG(duration_secs) as value FROM call_records WHERE duration_secs IS NOT NULL",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "mappings": [],
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 60
                },
                {
                  "color": "red",
                  "value": 180
                }
              ]
            },
            "unit": "s"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 4,
        "title": "Top Source Fleets",
        "type": "table",
        "targets": [
          {
            "expr": "",
            "format": "time_series",
            "intervalFactor": 1,
            "rawSql": "SELECT source_fleet, COUNT(*) as call_count FROM call_records WHERE source_fleet IS NOT NULL AND source_fleet != '' GROUP BY source_fleet ORDER BY COUNT(*) DESC LIMIT 10",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "align": "auto",
              "displayMode": "auto"
            },
            "mappings": [],
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 18,
          "y": 0
        }
      },
      {
        "id": 5,
        "title": "Call Duration Distribution",
        "type": "histogram",
        "targets": [
          {
            "expr": "",
            "format": "time_series",
            "intervalFactor": 1,
            "rawSql": "SELECT duration_secs FROM call_records WHERE duration_secs IS NOT NULL AND duration_secs > 0",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "hideFrom": {
                "tooltip": false,
                "vis": false,
                "legend": false
              }
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 6,
        "title": "Disconnection Causes",
        "type": "bargauge",
        "targets": [
          {
            "expr": "",
            "format": "time_series",
            "intervalFactor": 1,
            "rawSql": "SELECT disconnection_cause, COUNT(*) as value FROM call_records WHERE disconnection_cause IS NOT NULL GROUP BY disconnection_cause ORDER BY COUNT(*) DESC LIMIT 10",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "align": "auto",
              "displayMode": "auto"
            },
            "mappings": [],
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        }
      },
      {
        "id": 7,
        "title": "Service Types",
        "type": "table",
        "targets": [
          {
            "expr": "",
            "format": "time_series", 
            "intervalFactor": 1,
            "rawSql": "SELECT service_type, COUNT(*) as calls, AVG(duration_secs) as avg_duration FROM call_records WHERE service_type IS NOT NULL GROUP BY service_type ORDER BY COUNT(*) DESC",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "align": "auto",
              "displayMode": "auto"
            },
            "mappings": [],
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 16
        }
      }
    ],
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "timepicker": {},
    "uid": "universal-db-calls",
    "version": 1,
    "weekStart": ""
  }
}
