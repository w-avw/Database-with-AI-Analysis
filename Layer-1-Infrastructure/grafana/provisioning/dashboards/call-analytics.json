          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n    CASE \n        WHEN call_status IS NULL OR call_status = '' THEN 'Unknown'\n        ELSE call_status\n    END as call_status,\n    COUNT(*) as count\nFROM call_records \nGROUP BY call_status \nORDER BY count DESC \nLIMIT 10;",
